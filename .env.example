# ═══════════════════════════════════════════════════════════
#  FLOWORKOS™ Environment Configuration
# ═══════════════════════════════════════════════════════════
#  Copy this file to .env and fill in your values
#  AI CANNOT modify this file — only you can.
# ═══════════════════════════════════════════════════════════

# Mode: DEV = AI can evolve | PUBLISH = AI locked
FLOWORK_MODE=DEV

# ─── AI PROVIDER (Main LLM) ──────────────────────────────
# Provider: gemini | openai | anthropic | groq | deepseek | xai | mistral
FLOWORK_AI_PROVIDER=gemini
FLOWORK_AI_MODEL=gemini-2.5-flash
FLOWORK_AI_KEY=

# ─── BACKUP PROVIDERS (Failover) ─────────────────────────
# If main provider fails, auto-switch to these (in order)
FLOWORK_BACKUP_PROVIDER_1=openai
FLOWORK_BACKUP_MODEL_1=gpt-4o-mini
FLOWORK_BACKUP_KEY_1=

FLOWORK_BACKUP_PROVIDER_2=anthropic
FLOWORK_BACKUP_MODEL_2=claude-3-haiku-20240307
FLOWORK_BACKUP_KEY_2=

# ─── WHATSAPP (Meta Business API) ────────────────────────
# Get from: https://developers.facebook.com → WhatsApp
FLOWORK_WHATSAPP_ENABLED=false
FLOWORK_WHATSAPP_PHONE_ID=
FLOWORK_WHATSAPP_TOKEN=
FLOWORK_WHATSAPP_VERIFY_TOKEN=my_verify_token_123

# ─── TELEGRAM ────────────────────────────────────────────
# Get from: @BotFather on Telegram → /newbot
FLOWORK_TELEGRAM_ENABLED=false
FLOWORK_TELEGRAM_BOT_TOKEN=
FLOWORK_TELEGRAM_WEBHOOK_URL=

# ─── DISCORD ─────────────────────────────────────────────
# Get from: https://discord.com/developers/applications
FLOWORK_DISCORD_ENABLED=false
FLOWORK_DISCORD_BOT_TOKEN=
FLOWORK_DISCORD_APP_ID=

# ─── SLACK ───────────────────────────────────────────────
# Get from: https://api.slack.com/apps
FLOWORK_SLACK_ENABLED=false
FLOWORK_SLACK_BOT_TOKEN=
FLOWORK_SLACK_SIGNING_SECRET=

# ─── EMAIL (IMAP) ────────────────────────────────────────
# For AI email reading/sending capability
FLOWORK_EMAIL_HOST=
FLOWORK_EMAIL_PORT=993
FLOWORK_EMAIL_USER=
FLOWORK_EMAIL_PASSWORD=

# ─── VOICE / TTS ─────────────────────────────────────────
# Provider: browser | elevenlabs | openai-tts | google-tts
FLOWORK_TTS_PROVIDER=browser
FLOWORK_TTS_VOICE=

# ElevenLabs (https://elevenlabs.io)
FLOWORK_ELEVENLABS_KEY=
FLOWORK_ELEVENLABS_VOICE_ID=

# OpenAI TTS
FLOWORK_OPENAI_TTS_KEY=
FLOWORK_OPENAI_TTS_VOICE=alloy

# Google Cloud TTS (https://console.cloud.google.com)
FLOWORK_GOOGLE_TTS_KEY=

# ─── MEDIA / VISION ──────────────────────────────────────
# Vision provider: gemini-2.5-flash | gpt-4o | claude-sonnet-4-20250514
FLOWORK_VISION_PROVIDER=gemini-2.5-flash
FLOWORK_VISION_KEY=

# Whisper (Audio transcription) — uses OpenAI key
FLOWORK_WHISPER_KEY=

# ─── MCP SERVERS ──────────────────────────────────────────
# Connect to external MCP tool servers
# Format: name|transport|url (comma-separated for multiple)
# Example: filesystem|sse|http://localhost:3001,github|ws|ws://localhost:3002
FLOWORK_MCP_SERVERS=

# ─── RELAY SERVER (for receiving webhooks) ────────────────
# If you have a relay server for WhatsApp/Telegram webhooks
FLOWORK_RELAY_URL=
FLOWORK_RELAY_PORT=3000

# ─── SECURITY ────────────────────────────────────────────
# Auto-redact secrets in context (recommended: true)
FLOWORK_REDACTION_ENABLED=true
# Tool policy enforcement (recommended: true)
FLOWORK_TOOL_POLICY_ENABLED=true

# ─── SESSION ─────────────────────────────────────────────
# Auto-save sessions (recommended: true)
FLOWORK_SESSION_AUTOSAVE=true
# Session save interval in seconds
FLOWORK_SESSION_INTERVAL=30
